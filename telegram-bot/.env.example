# Telegram bot
# Get token from @BotFather → /newbot or /token
TELEGRAM_BOT_TOKEN=<paste-bot-token-here>
TELEGRAM_BOT_USERNAME=<your_bot_username>  # without @

# Default channel (will receive ALL signals until per-author routing is configured).
# Use channel ID (negative number like -1001234567890), NOT username.
# Get the ID by adding @userinfobot to the channel temporarily.
TELEGRAM_DEFAULT_CHAT_ID=

# Redis Streams (real-time signal bus)
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_KEY=signals:btc:4h
REDIS_CONSUMER_GROUP=tg_bot_v1
REDIS_CONSUMER_NAME=bot_main

# Postgres (audit log fallback if Redis lost a message)
POSTGRES_URL=postgres://elibri:elibri@localhost:5432/elibri

# Behavior
LOG_LEVEL=INFO
SIGNAL_FORMAT=default
DRY_RUN=false
