# Elibri FX Backend — environment variables
# Copy to .env (or pass via systemd EnvironmentFile) — .env is gitignored.
# See internal/config/config.go for the canonical list.

# ─── CORE ──────────────────────────────────────────────────────────────

# "development" (default) | "production"
# In production, the server REFUSES to start with the dev JWT secret.
GO_ENV=production

PORT=8080

# Postgres connection. docker-compose wires this automatically.
DATABASE_URL=postgresql://elibri:CHANGE_ME@localhost:5432/elibri?sslmode=disable

# Optional. Backend tolerates Redis being down (warns, continues).
REDIS_URL=redis://localhost:6379/0

# ─── AUTH (REQUIRED in production) ─────────────────────────────────────

# HMAC-SHA256 key. Generate with: openssl rand -hex 32
# Must be 32+ bytes. If left as the dev default and GO_ENV=production,
# the server log.Fatal's at startup.
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# Comma-separated. These emails get role=admin on first sign-in.
ADMIN_EMAILS=you@example.com

# ─── CORS ──────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins. Regex not supported.
CORS_ORIGINS=https://app.elibri.fx,http://localhost:5173

# ─── OPTIONAL INTEGRATIONS ─────────────────────────────────────────────

# Stocks fundamentals (crypto flow works without it).
FINNHUB_API_KEY=

# Crypto KOL tweets / Reddit — falls back to demo data if empty.
LUNARCRUSH_API_KEY=

# Binance — public market data works unauthenticated, keys needed for
# account queries / order placement.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ─── TELEGRAM (OPTIONAL — alerts stay in DB if empty) ──────────────────

# Get from @BotFather.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=ElibriFXBot

# ─── SCENARIO RUNNER QUOTAS ────────────────────────────────────────────

# Max active paper-trading scenarios per user (backend rejects the 6th).
SCENARIO_MAX_PER_USER=5

# Max Telegram alerts per user per 24h (backend skips TG delivery, keeps DB row).
ALERTS_MAX_PER_DAY=100

# Global emergency brake — 1 = reject all new /scenarios/*/start calls.
SCENARIO_KILL_SWITCH=0

# ─── ML THRESHOLD TUNING (development / experiments) ───────────────────

# Override per-model HC thresholds without regenerating best_thresholds.json.
# Format: SYMBOL_INTERVAL:value[,SYMBOL_INTERVAL:value...]
# Each override sets ThresholdHigh=value, ThresholdLow=1-value.
# Example for low-volatility paper trading:
#   ML_THRESHOLD_OVERRIDES=BTCUSDT_4h:0.60,BTCUSDT_1h:0.65
ML_THRESHOLD_OVERRIDES=
