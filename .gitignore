bin/
*.exe
.env

# Binaries & build artifacts
*.dll
*.so
*.dylib
elibri-backend
server
/tmp/

# Tests & coverage
*.test
*.out
coverage.html

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store

# ML training artifacts — don't commit models/data (too big, regeneratable)
ml-training/.venv/
ml-training/data/*.parquet
ml-training/models/*_v*.json
ml-training/models/*_patterns.json
ml-training/logs/
ml-training/__pycache__/
ml-training/**/__pycache__/

# Keep "latest.json" pointer for reference
!ml-training/models/latest.json

# Local model backups (safety copies, regeneratable from vast.ai)
ml-training/models.backup_*/
ml-training/models/*.bak.*
ml-training/models/*.patch*.bak.*

# Claude Flow metadata
.claude-flow/
.claude/

# Local env files & secrets (NEVER commit)
.env
.env.local
.env.*.local
